          "id": "q1",
          "text": "¿Cuál es el propósito principal de una estructura IF?",
          "options": [
            {
              "option": "a",
              "text": "Repetir código varias veces.",
              "explanation_correct": "",
              "explanation_wrong": "Eso corresponde a los loops."
            },
            {
              "option": "b",
              "text": "Tomar decisiones según una condición.",
              "explanation_correct": "Correcto, IF permite ejecutar código solo cuando una condición se cumple.",
              "explanation_wrong": ""
            },
            {
              "option": "c",
              "text": "Crear objetos en memoria.",
              "explanation_correct": "",
              "explanation_wrong": "IF no se utiliza para crear objetos."
            }
          ],
          "answer": "b",
          "image": ""
        },
        {
          "id": "q2",
          "text": "¿Qué ocurre cuando la condición de un IF es falsa y existe un ELSE?",
          "options": [
            {
              "option": "a",
              "text": "Se ejecuta el bloque ELSE.",
              "explanation_correct": "Correcto, ELSE se ejecuta cuando la condición del IF no se cumple.",
              "explanation_wrong": ""
            },
            {
              "option": "b",
              "text": "Se ejecutan ambos bloques.",
              "explanation_correct": "",
              "explanation_wrong": "Solo se ejecuta uno de los bloques."
            },
            {
              "option": "c",
              "text": "El programa termina.",
              "explanation_correct": "",
              "explanation_wrong": "El programa continúa normalmente."
            }
          ],
          "answer": "a",
          "image": ""
        },
        {
          "id": "q3",
          "text": "¿Qué es un IF anidado?",
          "options": [
            {
              "option": "a",
              "text": "Un IF dentro de otro IF.",
              "explanation_correct": "Correcto, permite validar múltiples condiciones relacionadas.",
              "explanation_wrong": ""
            },
            {
              "option": "b",
              "text": "Un FOR dentro de un WHILE.",
              "explanation_correct": "",
              "explanation_wrong": "Eso son loops anidados."
            },
            {
              "option": "c",
              "text": "Un ELSE sin IF.",
              "explanation_correct": "",
              "explanation_wrong": "ELSE siempre depende de un IF."
            }
          ],
          "answer": "a",
          "image": ""
        },
